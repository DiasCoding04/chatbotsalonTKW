NODE_ENV=production
APP_PUBLIC_URL=https://chatbot.salontukawa.com

GEMINI_BACKEND=vertex
VERTEX_AI_PROJECT_ID=gen-lang-client-0335766885
VERTEX_AI_LOCATION=global
VERTEX_AI_MODEL=gemini-3.1-flash-lite
GOOGLE_APPLICATION_CREDENTIALS=/home/snqiajdjhosting/secure/vertex-sa.json
# Or use VERTEX_SERVICE_ACCOUNT_JSON instead of GOOGLE_APPLICATION_CREDENTIALS
# VERTEX_SERVICE_ACCOUNT_JSON={...json...}

DEBUG_UPSTREAM_TIMING=1

CONTEXT_CACHE_SERVER_PORT=8787
CONTEXT_CACHE_SERVER_HOST=127.0.0.1
# Production khuyến nghị 3600 (1h). Idle không tin 30 phút → xóa cache (GEMINI_CONTEXT_CACHE_IDLE_MS).
GEMINI_CONTEXT_CACHE_TTL_S=3600
GEMINI_CONTEXT_CACHE_IDLE_MS=1800000
# Một CONTEXT — Firestore (Training PUT = toàn hệ thống). Local dev: CONTEXT_BACKEND=file
CONTEXT_BACKEND=firestore
CONTEXT_FIRESTORE_DOC_ID=salon_context
# Bỏ dòng này → server production mặc định 3600. Tiết kiệm thử nghiệm: GEMINI_CONTEXT_CACHE_COST_MODE=aggressive (600)
# Purge 100% cache trên Google/Vertex (list API + xoá) — mặc định BẬT. Tắt: =0
# GEMINI_CONTEXT_CACHE_PURGE_ON_STARTUP=0
# GEMINI_CONTEXT_CACHE_PURGE_ON_SHUTDOWN=0
CONTEXT_MAX_CHARS=500000
# Giới hạn độ dài systemPrompt cho POST /api/context-cache/ensure (mặc định ~min(950k, CONTEXT_MAX_CHARS*2))
# GEMINI_ENSURE_SYSTEM_PROMPT_MAX_CHARS=900000
# Timeout (ms) khi gọi Vertex API tạo cachedContent — tránh treo vô hạn (mặc định 120000 nếu set > 5000)
# GEMINI_VERTEX_CREATE_CACHE_FETCH_MS=120000
# Timeout (ms) khi gọi Developer API tạo cache (API key) — tương tự
# GEMINI_DEV_CREATE_CACHE_FETCH_MS=120000
CONTEXT_EDITOR_TOKEN=replace-with-long-random-token

VITE_AI_PROVIDER=gemini
VITE_GEMINI_MODEL=gemini-3.1-flash-lite
VITE_GEMINI_PROXY_INJECTS_KEY=true
VITE_CONTEXT_CACHE_SCOPE=server
VITE_MAX_OUTPUT_TOKENS=256
VITE_USD_VND=26000

# Public base URL for image sample catalog (recommended: Cloud Storage bucket URL)
# Example: https://storage.googleapis.com/chatbot-tkw-assets
IMAGE_SAMPLES_BASE_URL=

# AI inbox Facebook: tự trả lời (0 = tắt)
# FACEBOOK_AI_AUTO_REPLY=0
# Chờ khách ngừng nhắn rồi gom 1 lượt trả lời (ms; mặc định 20000)
# FACEBOOK_AI_REPLY_DEBOUNCE_MS=20000
# Retry khi webhook đã lưu tin nhưng Gemini/Graph/claim lỗi tạm (không quét Firestore định kỳ)
# FACEBOOK_AI_REPLY_MAX_RETRIES=5
# FACEBOOK_AI_REPLY_RETRY_DELAY_MS=12000
# Cache TTL đọc inbox store Firestore mỗi instance (ms). Khuyến nghị >= poll UI (15–30s). Mặc định 30000.
# Cache đọc inbox store mỗi instance (ms). Nên >= chu kỳ poll UI (15s). Mặc định 60000.
# FACEBOOK_STORE_READ_CACHE_MS=60000
# Hội thoại đang mở (?focus=id): tối đa N tin đầy đủ. Mặc định 12.
# FACEBOOK_INBOX_API_MAX_MESSAGES=12
# Tối đa hội thoại mỗi lần poll. Mặc định 100.
# FACEBOOK_INBOX_API_MAX_CONVERSATIONS=100
# Hội thoại không mở: chỉ N tin preview (không URL ảnh). Mặc định 3.
# FACEBOOK_INBOX_API_LIST_PREVIEW_MESSAGES=3
# Cache TTL đọc token vault Firestore (ms; 0 = bỏ cache). Mặc định 30000.
# FACEBOOK_TOKEN_VAULT_CACHE_MS=30000
# Ghi data/facebook-webhook-last.json mỗi webhook. Mặc định TẮT trên Cloud Run.
# Bật để debug payload mới nhất: FACEBOOK_WEBHOOK_DEBUG_FILE=1
# User token (long-lived) — server tự refresh page token + lưu Firestore vault (không mất khi redeploy)
# FACEBOOK_USER_ACCESS_TOKEN=
# FACEBOOK_TOKEN_REFRESH_ON_STARTUP=1
# FACEBOOK_TOKEN_REFRESH_INTERVAL_HOURS=6
# FACEBOOK_SKIP_USER_TOKEN_EXCHANGE=1
# FACEBOOK_TOKEN_VAULT_BACKEND=firestore
# Chạy tay cập nhật deploy/env: npm run facebook:refresh-tokens

# Proxy ảnh CDN Facebook (GET /api/facebook/cdn-media): trần byte + timeout fetch (mặc định ~12MiB, 25s)
# FACEBOOK_CDN_PROXY_MAX_BYTES=12582912
# FACEBOOK_CDN_PROXY_FETCH_MS=25000
