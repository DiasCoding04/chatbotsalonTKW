# Copy to .env (dev) hoặc /etc/salon-chat-gemini.env (production server).

# --- Frontend (Vite build) ---
VITE_AI_PROVIDER=gemini
VITE_GEMINI_MODEL=gemini-3.1-flash-lite
VITE_CONTEXT_CACHE_SCOPE=server
VITE_MAX_OUTPUT_TOKENS=256
VITE_USD_VND=26000

# Dev local: key trong bundle. Production: dùng .env.production + GEMINI_API_KEY trên server.
VITE_GEMINI_API_KEY=
# Production build: true (xem .env.production.example)
# VITE_GEMINI_PROXY_INJECTS_KEY=true

# --- Node server (dev + production) ---
NODE_ENV=development
APP_PUBLIC_URL=https://chatbot.salontukawa.com
CONTEXT_CACHE_SERVER_PORT=8787
CONTEXT_CACHE_SERVER_HOST=127.0.0.1
GEMINI_CONTEXT_CACHE_TTL_S=3600
# TTL càng dài → ít phải tạo lại cache trên Google (rẻ hơn). Giới hạn tối đa do API (thường ≤ 24h).
CONTEXT_MAX_CHARS=500000

# Production: đặt key server-side (không bake vào dist).
GEMINI_API_KEY=

# Bắt buộc khi NODE_ENV=production — token PUT /api/context.
CONTEXT_EDITOR_TOKEN=

# --- Facebook Messenger sync ---
# Dùng cho /api/facebook/status, /api/facebook/sync, /api/facebook/webhook và POST /api/facebook/send (gửi tin từ inbox lên Messenger).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional: nhiều page token, phân tách bằng dấu phẩy.
FACEBOOK_PAGE_ACCESS_TOKENS=
FACEBOOK_VERIFY_TOKEN=
# Sau webhook (tin khách), server gọi Gemini + Context Cache giống Training rồi gửi Messenger. Tắt: FACEBOOK_AI_AUTO_REPLY=0
# FACEBOOK_AI_AUTO_REPLY=0
# Optional: domain public trỏ vào server backend, ví dụ https://api.example.com
FACEBOOK_WEBHOOK_PUBLIC_URL=
# Mỗi POST webhook ghi đè data/facebook-webhook-last.json (có PSID). Tắt hoàn toàn: FACEBOOK_WEBHOOK_NO_DEBUG_FILE=1
# In JSON ra stdout (thêm): FACEBOOK_WEBHOOK_LOG_RAW_BODY=1
# Graph lỗi — chi tiết response: FACEBOOK_WEBHOOK_DEBUG_GRAPH=1
# Tắt gọi Graph GET /{mid}/attachments khi webhook không có URL ảnh/video (mặc định bật).
# FACEBOOK_DISABLE_GRAPH_ATTACHMENTS=1

# Optional: override data/CONTEXT.md path
# CONTEXT_DATA_DIR=
# CONTEXT_DATA_PATH=
