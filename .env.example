# Copy to .env (dev) hoặc /etc/salon-chat-gemini.env (production server).

# --- Frontend (Vite build) ---
VITE_AI_PROVIDER=gemini
VITE_GEMINI_MODEL=gemini-3.1-flash-lite
VITE_CONTEXT_CACHE_SCOPE=server
VITE_MAX_OUTPUT_TOKENS=256
VITE_USD_VND=26000

# Dev local: key trong bundle. Production: dùng .env.production + GEMINI_API_KEY trên server.
VITE_GEMINI_API_KEY=
# Production build: true (xem .env.production.example)
# VITE_GEMINI_PROXY_INJECTS_KEY=true

# --- Node server (dev + production) ---
NODE_ENV=development
APP_PUBLIC_URL=https://chatbot.salontukawa.com
CONTEXT_CACHE_SERVER_PORT=8787
CONTEXT_CACHE_SERVER_HOST=127.0.0.1
GEMINI_CONTEXT_CACHE_TTL_S=3600
CONTEXT_MAX_CHARS=500000

# Production: đặt key server-side (không bake vào dist).
GEMINI_API_KEY=

# Bắt buộc khi NODE_ENV=production — token PUT /api/context.
CONTEXT_EDITOR_TOKEN=

# Optional: override data/CONTEXT.md path
# CONTEXT_DATA_DIR=
# CONTEXT_DATA_PATH=
