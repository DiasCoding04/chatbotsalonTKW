# Copy thành .env.production rồi build trên máy local (npm run build:prod).

VITE_AI_PROVIDER=gemini
VITE_GEMINI_MODEL=gemini-3.1-flash-lite
VITE_GEMINI_API_KEY=your-gemini-key
# false = key nằm trong dist (tiện, không bảo mật). true = key chỉ trên server.
VITE_GEMINI_PROXY_INJECTS_KEY=false
VITE_CONTEXT_CACHE_SCOPE=server
VITE_MAX_OUTPUT_TOKENS=256
VITE_USD_VND=26000

# Public URL for the deployed app and Facebook webhook callbacks
APP_PUBLIC_URL=https://chatbot.salontukawa.com
FACEBOOK_WEBHOOK_PUBLIC_URL=https://chatbot.salontukawa.com

# Runtime server settings
CONTEXT_CACHE_SERVER_PORT=8080
# Set this in production before deploying to prevent unauthorized CONTEXT edits.
# CONTEXT_EDITOR_TOKEN=

# Vertex AI backend
GEMINI_BACKEND=vertex
VERTEX_AI_PROJECT_ID=your-gcp-project-id
# Use one of the following for Vertex authentication:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# VERTEX_SERVICE_ACCOUNT_JSON={...json...}
